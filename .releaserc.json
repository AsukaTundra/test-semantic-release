{
  "tagFormat": "release-v${version}",
  "branches": [
    { "name": "pre-release", "prerelease": "rc" },
    { "name": "release", "channel": "latest" }
  ],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits",
        "releaseRules": [
          { "branch": "release", "type": "feat", "release": "minor" },
          { "branch": "release", "type": "fix", "release": "patch" },
          {
            "branch": "release",
            "type": "BREAKING CHANGE",
            "release": "major"
          },
          { "type": "chore", "release": false }
        ]
      }
    ],
    "@semantic-release/release-notes-generator",
    [
      "semantic-release-mirror-version",
      {
        "fileGlob": "./.env.example",
        "placeholderRegExp": "(?<=APP_VERSION=)[^\\r\\n]+"
      }
    ],
    [
      "@semantic-release/npm",
      {
        "npmPublish": false,
        "tarballDir": "dist"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["package.json", ".env.example"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "githubUrl": "https://github.com",
        "failTitle": false
      }
    ]
  ]
}
